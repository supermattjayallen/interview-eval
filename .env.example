OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
WHISPER_MODEL=whisper-1
MAX_RECORDING_DURATION_SECONDS=7200
TEMP_DIR=./tmp
RESULTS_DIR=./data/results
JOBS_DIR=./data/jobs

# PostgreSQL question bank (optional — enables scalable prep and question search)
# Local app + Docker Postgres: postgresql+psycopg2://interview_eval:interview_eval@localhost:5432/interview_eval
# Full docker compose sets this automatically for the app container.
DATABASE_URL=

# Team access (recommended when sharing the service with teammates)
# When both are set, the web UI and API require HTTP Basic Auth.
TEAM_USERNAME=
TEAM_PASSWORD=

# Optional Google Drive storage
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=your-shared-folder-id
